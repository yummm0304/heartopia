# ============================================================
#  .gitignore - 두근두근타운
# ============================================================


# ── JetBrains IDE (IntelliJ IDEA, PyCharm, WebStorm 등) ──────
.idea/
*.iml
*.iws
*.ipr
out/


# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ── Windows ──────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/


# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*


# ── 환경변수 / 시크릿 ────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.*


# ── 로그 ─────────────────────────────────────────────────────
*.log
logs/


# ── 에디터 공통 ──────────────────────────────────────────────
*.swp
*.swo
*~
.vscode/


# ── 작업 메모 ─────────────────────────────────────────
CLAUDE.md
CLAUDE_MEMO.md

*.xlsx
*.csv

# ── 이미 올라간 파일 깃에서 제거 ─────────────────────────────────────────
# git rm --cached -r --ignore-unmatch **/*.xlsx